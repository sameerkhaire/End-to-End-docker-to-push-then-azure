dir certs
COPY certs/devcert.pfx /https/devcert.pfx
builder.WebHost.ConfigureKestrel(options =>
{
    options.Listen(IPAddress.Any, 8080); // HTTP
    options.Listen(IPAddress.Any, 8443, listenOptions =>
    {
        listenOptions.UseHttps("/https/devcert.pfx", "Sam7038@");
    });
});
docker build -t ecommerceapi .
docker run -d -p 8080:8080 -p 8081:8081 ecommerceapi


az acr create --resource-group ecommerce-rg --name ecommerceacrsameer2026 --sku Basic --admin-enabled true


az appservice plan create ^
--name ecommerce-app-plan ^
--resource-group ecommerce-rg ^
--is-linux ^
--sku B1

az webapp create ^
--resource-group ecommerce-rg ^
--plan ecommerce-app-plan ^
--name ecommerce-api-sameer-2026 ^
--deployment-container-image-name ecommerceacrsameer2026.azurecr.io/ecommerceapi:v1

az webapp config container set ^
--name ecommerce-api-sameer-2026 ^
--resource-group ecommerce-rg ^
--docker-custom-image-name ecommerceacrsameer2026.azurecr.io/ecommerceapi:v1 ^
--docker-registry-server-url https://ecommerceacrsameer2026.azurecr.io ^
--docker-registry-server-user ecommerceacrsameer2026 ^
--docker-registry-server-password <ACR_PASSWORD>

az webapp config appsettings set ^
--resource-group ecommerce-rg ^
--name ecommerce-api-sameer-2026 ^
--settings WEBSITES_PORT=8080

az webapp restart ^
--name ecommerce-api-sameer-2026 ^
--resource-group ecommerce-rg
